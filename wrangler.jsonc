{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "buddy-blocks",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-01",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "buddy_blocks",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "vars": {
    "TIME_ZONE": "America/Chicago"
  },
  "observability": {
    "enabled": true
  }
}

