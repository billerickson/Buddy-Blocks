---
import BrandMark from '../components/BrandMark.astro';
import PublicFooter from '../components/PublicFooter.astro';
import Seo from '../components/Seo.astro';
import OfflineSyncBoot from '../components/islands/offline/OfflineSyncBoot';
import { DEFAULT_SITE_DESCRIPTION, isIndexableMarketingPath, type BreadcrumbEntry, type JsonLd } from '../lib/seo';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
  active?: 'profiles' | 'parent' | 'kid';
  brandHref?: string;
  canonicalPath?: string;
  noindex?: boolean;
  image?: string;
  imageAlt?: string;
  breadcrumbs?: BreadcrumbEntry[];
  structuredData?: JsonLd;
}

const {
  title,
  description = DEFAULT_SITE_DESCRIPTION,
  showNav = true,
  active,
  brandHref,
  canonicalPath,
  noindex,
  image,
  imageAlt,
  breadcrumbs,
  structuredData,
} = Astro.props;
const kidPathMatch = Astro.url.pathname.match(/^\/kid\/([^/]+)/);
const generatedKidShellSlugs = new Set(['shell', 'track-shell', 'lesson-shell']);
const isGeneratedKidShell = active === 'kid' && kidPathMatch ? generatedKidShellSlugs.has(kidPathMatch[1]) : false;
const resolvedBrandHref =
  brandHref ?? (active === 'kid' && kidPathMatch && !isGeneratedKidShell ? `/kid/${kidPathMatch[1]}/` : '/profiles/');
const shouldResolveKidHomeLink = active === 'kid' && !brandHref;
const resolvedNoindex = noindex ?? !isIndexableMarketingPath(Astro.url.pathname);
const shouldBootOfflineSync = active === 'profiles' || active === 'parent' || active === 'kid';
const shouldShowAppFooter = shouldBootOfflineSync;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      noindex={resolvedNoindex}
      image={image}
      imageAlt={imageAlt}
      breadcrumbs={breadcrumbs}
      structuredData={structuredData}
    />
  </head>
  <body class="blocks">
    {showNav && (
      <header class="topbar">
        <div class="app-shell topbar-inner">
          <BrandMark href={resolvedBrandHref} kidHome={shouldResolveKidHomeLink} />
          <button class="mobile-menu-toggle" type="button" aria-label="Open menu" aria-controls="site-menu" aria-expanded="false" data-mobile-menu-toggle>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
          <nav class="nav-links" id="site-menu" aria-label="Main" data-mobile-menu>
            <a class="nav-link" href="/profiles/" aria-current={active === 'profiles' ? 'page' : undefined}>Profiles</a>
            <a class="nav-link" href="/parent/" aria-current={active === 'parent' ? 'page' : undefined}>Parent</a>
            <a class="nav-link" href="/logout/">Log out</a>
          </nav>
        </div>
      </header>
    )}
    <slot />
    {shouldShowAppFooter && <PublicFooter />}
    {shouldBootOfflineSync && <OfflineSyncBoot client:load />}
    {shouldResolveKidHomeLink && (
      <script is:inline>
        const kidHomeLink = document.querySelector('[data-kid-home-link]');
        const kidPathMatch = window.location.pathname.match(/^\/kid\/([^/]+)(?:\/|$)/);
        const generatedKidShellSlugs = new Set(['shell', 'track-shell', 'lesson-shell']);
        if (kidHomeLink && kidPathMatch && !generatedKidShellSlugs.has(kidPathMatch[1])) {
          kidHomeLink.setAttribute('href', `/kid/${kidPathMatch[1]}/`);
        }
      </script>
    )}
    <script is:inline>
      const mobileMenuToggle = document.querySelector('[data-mobile-menu-toggle]');
      const mobileMenu = document.querySelector('[data-mobile-menu]');

      if (mobileMenuToggle && mobileMenu) {
        const setMobileMenuOpen = (open) => {
          mobileMenuToggle.setAttribute('aria-expanded', String(open));
          mobileMenuToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          document.body.toggleAttribute('data-mobile-menu-open', open);
        };

        mobileMenuToggle.addEventListener('click', () => {
          setMobileMenuOpen(mobileMenuToggle.getAttribute('aria-expanded') !== 'true');
        });

        mobileMenu.addEventListener('click', (event) => {
          const target = event.target;
          if (target instanceof Element && target.closest('a')) setMobileMenuOpen(false);
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth >= 768) setMobileMenuOpen(false);
        });
      }
    </script>
    {shouldBootOfflineSync && (
      <script is:inline>
        if ('serviceWorker' in navigator) {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register('/service-worker.js').catch(() => {});
          });
        }
      </script>
    )}
  </body>
</html>
