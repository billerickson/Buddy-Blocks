---
import BrandMark from './BrandMark.astro';

interface Props {
  active?: 'home' | 'courses';
}

const { active } = Astro.props;
---

<header class="topbar">
  <div class="app-shell topbar-inner">
    <BrandMark href="/" />
    <button class="mobile-menu-toggle" type="button" aria-label="Open menu" aria-controls="public-site-menu" aria-expanded="false" data-mobile-menu-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <nav class="nav-links public-nav" id="public-site-menu" aria-label="Main" data-mobile-menu>
      <a class="nav-link" href="/" aria-current={active === 'home' ? 'page' : undefined}>Home</a>
      <a class="nav-link" href="/courses/" aria-current={active === 'courses' ? 'page' : undefined}>Courses</a>
      <a class="nav-link nav-login-link" href="/login/">Log In</a>
    </nav>
  </div>
</header>

<style>
  .public-nav {
    justify-content: flex-end;
  }

  @media (max-width: 520px) {
    .public-nav {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
