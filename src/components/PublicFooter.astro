---
const githubUrl = 'https://github.com/billerickson/Buddy-Blocks';
---

<footer class="public-footer">
  <div class="app-shell public-footer-inner">
    <div class="public-footer-credit">
      <a
        class="public-footer-mark"
        href="https://billerickson.net"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Bill Erickson website"
      >
        <img src="/icons/bill-erickson-be-mark.png" alt="" width="32" height="32" loading="lazy" decoding="async" />
      </a>
      <p>Developed by Bill, Reagan, and Ada Erickson</p>
    </div>
    <a class="public-footer-link" href={githubUrl} target="_blank" rel="noopener noreferrer">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path
          fill="currentColor"
          d="M12 2C6.48 2 2 6.58 2 12.24c0 4.53 2.86 8.37 6.84 9.73.5.09.68-.22.68-.49v-1.9c-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.11-1.49-1.11-1.49-.91-.63.07-.62.07-.62 1.01.07 1.54 1.06 1.54 1.06.89 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.36 9.36 0 0 1 12 6.98c.85 0 1.69.12 2.49.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9v2.79c0 .27.18.59.69.49A10.1 10.1 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z"
        />
      </svg>
      <span>GitHub Repo</span>
    </a>
  </div>
</footer>

<style>
  .public-footer {
    border-top: 2px solid color-mix(in srgb, var(--line) 70%, transparent);
    background: var(--paper);
  }

  .public-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-block: 18px;
  }

  .public-footer-credit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-weight: 900;
  }

  .public-footer-mark {
    display: inline-flex;
    flex: 0 0 auto;
  }

  .public-footer-mark img {
    width: 32px;
    height: 32px;
    border-radius: 8px;
  }

  .public-footer-credit p {
    margin: 0;
  }

  .public-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    font-weight: 1000;
    text-decoration-thickness: 3px;
    text-underline-offset: 4px;
  }

  .public-footer-link svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  @media (max-width: 640px) {
    .public-footer-inner {
      align-items: center;
      flex-direction: column;
      gap: 10px;
      width: 100vw;
      margin-inline: 0;
      padding-inline: 10px;
      text-align: center;
    }

    .public-footer-credit {
      justify-content: center;
      gap: 6px;
      font-size: clamp(0.5rem, 2.25vw, 0.62rem);
      white-space: nowrap;
    }

    .public-footer-mark img {
      width: 18px;
      height: 18px;
    }

    .public-footer-link {
      justify-content: center;
    }
  }
</style>
