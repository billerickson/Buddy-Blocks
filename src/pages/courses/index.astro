---
import CourseQuestionMockup from '../../components/CourseQuestionMockup.astro';
import PublicFooter from '../../components/PublicFooter.astro';
import PublicTopbar from '../../components/PublicTopbar.astro';
import AppLayout from '../../layouts/AppLayout.astro';
import { getCourseFamilies } from '../../lib/public-courses';
import { SITE_NAME, absoluteUrl, courseFamilyGraph, resolveSiteUrl, webPageGraph } from '../../lib/seo';

const families = getCourseFamilies();
const totals = families.reduce(
  (summary, family) => ({
    levels: summary.levels + family.stats.levels,
    units: summary.units + family.stats.units,
    lessons: summary.lessons + family.stats.lessons,
    questions: summary.questions + family.stats.questions,
  }),
  { levels: 0, units: 0, lessons: 0, questions: 0 },
);
const coursesTitle = 'Buddy Blocks Courses | Classical Learning Paths for Kids';
const coursesDescription =
  'Explore Buddy Blocks courses for math, vocabulary, languages, grammar, logic, rhetoric, literature, history, civics, and memory work, including four Grammar levels.';
const siteUrl = resolveSiteUrl(Astro.site);
const coursesCanonical = absoluteUrl(siteUrl, '/courses/');
const coursesGraph = webPageGraph({
  site: siteUrl,
  canonicalUrl: coursesCanonical,
  title: coursesTitle,
  description: coursesDescription,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'Courses', path: '/courses/' },
  ],
  pageType: 'CollectionPage',
  extra: [
    {
      '@type': 'ItemList',
      '@id': `${coursesCanonical}#course-list`,
      name: `${SITE_NAME} Course Families`,
      numberOfItems: families.length,
      itemListElement: families.map((family, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: { '@id': `${absoluteUrl(siteUrl, `/courses/${family.slug}/`)}#course` },
      })),
    },
    ...families.map((family) => courseFamilyGraph(siteUrl, family)),
  ],
});
---

<AppLayout
  title={coursesTitle}
  description={coursesDescription}
  canonicalPath="/courses/"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Courses', path: '/courses/' },
  ]}
  structuredData={coursesGraph}
  showNav={false}
>
  <PublicTopbar active="courses" />

  <main>
    <section class="app-shell course-hero">
      <div class="course-hero-copy">
        <h1>Courses that build lasting skills, step by step.</h1>
        <p class="mt-5 max-w-3xl text-xl font-extrabold text-muted">
          Buddy Blocks gives students a clear path through a classical education with short, engaging lessons that build lasting understanding. The course library now includes four Grammar levels, from sentence foundations through purposeful revision, plus five Classical Literature levels alongside math, languages, logic, rhetoric, history, civics, and memory work.
        </p>
        <div class="course-stat-row mt-7" aria-label="Curriculum totals">
          <span><strong>{totals.levels}</strong> levels</span>
          <span><strong>{totals.units}</strong> units</span>
          <span><strong>{totals.lessons}</strong> lesson briefs</span>
          <span><strong>{totals.questions.toLocaleString()}</strong> question prompts</span>
        </div>
      </div>

      <div class="course-dashboard" aria-label="Sample course dashboard mockup">
        <div class="course-dashboard-top">
          <span>Course Library</span>
          <span>{families.length} course families</span>
        </div>
        <div class="course-dashboard-body">
          {families.map((family) => (
            <a class="course-dashboard-row" href={`/courses/${family.slug}/`} style={`--course-color: ${family.color};`}>
              <span>
                <strong>{family.title}</strong>
                <small>{family.levelRange}<br />{family.stats.lessons} lesson briefs</small>
              </span>
              <b>{family.stats.levels}</b>
            </a>
          ))}
        </div>
      </div>
    </section>

    {families.map((family) => (
      <section class="course-family-band" id={family.slug} style={`--course-color: ${family.color}; --course-accent: ${family.accent};`}>
        <div class="app-shell course-family-layout">
          <div class="course-family-copy">
            <h2>{family.title}</h2>
            <p class="course-summary">{family.summary}</p>
            <div class="course-paragraphs">
              {family.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>

            <div class="course-footer">
              <div class="course-mini-stats">
                <span>{family.levelRange}</span>
                <span>{family.stats.units} units</span>
                <span>{family.stats.lessons} lesson briefs</span>
                <span>{family.stats.questions.toLocaleString()} question prompts</span>
              </div>
              <a class="primary-button" href={`/courses/${family.slug}/`}>More Information</a>
            </div>
          </div>

          <div class="course-mockup-stack" aria-label={`${family.title} example questions`}>
            {family.mockups.map((mockup) => <CourseQuestionMockup mockup={mockup} compact />)}
          </div>
        </div>
      </section>
    ))}
  </main>

  <PublicFooter />

  <style>
    .course-hero {
      display: grid;
      min-height: calc(100vh - 72px);
      grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
      gap: 36px;
      align-items: center;
      padding-block: 42px;
    }

    .course-hero h1 {
      max-width: 830px;
      font-size: clamp(2rem, 5vw, 4.4rem);
      line-height: 0.94;
    }

    .course-stat-row,
    .course-mini-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .course-stat-row span,
    .course-mini-stats span {
      display: inline-flex;
      min-height: 40px;
      align-items: center;
      gap: 6px;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 8px 11px;
      font-weight: 950;
    }

    .course-stat-row strong {
      font-family: var(--font-display);
      font-size: 1.25rem;
    }

    .course-dashboard {
      overflow: hidden;
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      box-shadow: 6px 6px 0 var(--block-shadow);
      transform: rotate(1deg);
    }

    .course-dashboard-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 3px solid var(--ink);
      background: var(--secondary);
      padding: 14px 16px;
      font-weight: 1000;
    }

    .course-dashboard-body {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      padding: 18px;
      background:
        linear-gradient(135deg, rgba(91, 121, 255, 0.13) 0 18%, transparent 18% 100%),
        linear-gradient(225deg, rgba(230, 62, 128, 0.1) 0 18%, transparent 18% 100%),
        #fffaf0;
    }

    .course-dashboard-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      border: 2px solid var(--ink);
      border-left: 12px solid var(--course-color);
      border-radius: 8px;
      background: white;
      padding: 13px 14px;
      font-weight: 950;
      text-decoration: none;
    }

    .course-dashboard-row small {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-weight: 850;
    }

    .course-dashboard-row b {
      display: inline-grid;
      min-width: 42px;
      height: 42px;
      place-items: center;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--secondary);
      font-family: var(--font-display);
      font-size: 1.15rem;
    }

    .course-family-band {
      border-top: 2px solid color-mix(in srgb, var(--line) 70%, transparent);
    }

    .course-family-band {
      padding-block: 56px;
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--course-color) 12%, transparent), transparent 42%),
        color-mix(in srgb, var(--paper) 72%, transparent);
    }

    .course-family-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.12fr) minmax(310px, 0.88fr);
      gap: 32px;
      align-items: start;
    }

    .course-family-copy h2 {
      font-size: clamp(2.4rem, 5vw, 4.4rem);
    }

    .course-summary {
      margin-top: 14px;
      max-width: 760px;
      color: var(--muted);
      font-size: 1.2rem;
      font-weight: 900;
    }

    .course-paragraphs {
      display: grid;
      max-width: 820px;
      gap: 12px;
      margin-top: 20px;
      color: var(--muted);
      font-weight: 800;
    }

    .course-footer {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      align-items: center;
      justify-content: space-between;
      margin-top: 26px;
    }

    .course-mini-stats span {
      min-height: 34px;
      border-color: color-mix(in srgb, var(--ink) 70%, var(--course-color));
      font-size: 0.9rem;
    }

    .course-mockup-stack {
      display: grid;
      gap: 18px;
    }

    @media (max-width: 900px) {
      .course-hero,
      .course-family-layout {
        grid-template-columns: 1fr;
      }

      .course-hero {
        min-height: auto;
      }

      .course-dashboard {
        transform: none;
      }
    }

    @media (max-width: 520px) {
      .course-dashboard-body {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 767px) {
      .course-hero {
        padding-block: 28px;
      }

      .course-family-band {
        padding-block: 32px;
      }

      .course-footer {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</AppLayout>
