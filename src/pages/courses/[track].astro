---
import CourseQuestionMockup from '../../components/CourseQuestionMockup.astro';
import PublicTopbar from '../../components/PublicTopbar.astro';
import AppLayout from '../../layouts/AppLayout.astro';
import { getCourseFamilies, getCourseLevels, type CourseFamily } from '../../lib/public-courses';

interface Props {
  family: CourseFamily;
}

export function getStaticPaths() {
  return getCourseFamilies().map((family) => ({
    params: { track: family.slug },
    props: { family },
  }));
}

const { family } = Astro.props;
const levels = getCourseLevels(family);
---

<AppLayout title={`${family.title} Courses | Buddy Blocks`} showNav={false}>
  <PublicTopbar active="courses" />

  <main style={`--course-color: ${family.color}; --course-accent: ${family.accent};`}>
    <section class="app-shell track-hero">
      <div>
        <a class="back-link" href="/courses/">All Courses</a>
        <p class="mt-5 font-black uppercase text-berryDark">{family.eyebrow}</p>
        <h1>{family.title}</h1>
        <p class="mt-5 max-w-3xl text-xl font-extrabold text-muted">{family.summary}</p>
        <div class="track-stat-row mt-7" aria-label={`${family.title} course totals`}>
          <span>{family.levelRange}</span>
          <span>{family.stats.units} units</span>
          <span>{family.stats.lessons} lessons</span>
          <span>{family.stats.questions.toLocaleString()} questions</span>
        </div>
      </div>

      <div class="track-hero-panel">
        <h2>Students will...</h2>
        <div class="track-outcome-list">
          <div>
            <strong>Learn</strong>
            <p>{family.learn.join(', ')}</p>
          </div>
          <div>
            <strong>Master</strong>
            <p>{family.master.join(', ')}</p>
          </div>
          <div>
            <strong>Complete</strong>
            <p>{family.complete.join(', ')}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="level-nav-band">
      <div class="app-shell level-nav">
        <div>
          <p class="font-black uppercase text-berryDark">Levels</p>
          <h2 class="mt-2 text-4xl">What each level covers</h2>
        </div>
        <nav aria-label={`${family.title} levels`}>
          {levels.map((level) => <a href={`#${level.track.slug}`}>{level.label}</a>)}
        </nav>
      </div>
    </section>

    {levels.map((level) => (
      <section class="level-section" id={level.track.slug}>
        <div class="app-shell level-layout">
          <article class="level-copy">
            <p class="level-kicker">{level.label}</p>
            <h2>{level.track.title}</h2>
            <div class="level-stat-row" aria-label={`${level.track.title} totals`}>
              <span>{level.stats.units} units</span>
              <span>{level.stats.lessons} lessons</span>
              <span>{level.stats.questions} questions</span>
            </div>
            <div class="level-paragraphs">
              {level.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>

            <div class="unit-strip" aria-label={`${level.track.title} units`}>
              {level.unitTitles.slice(0, 8).map((unit) => <span>{unit}</span>)}
              {level.unitTitles.length > 8 && <span>{level.unitTitles.length - 8} more units</span>}
            </div>
          </article>

          <div class="level-examples" aria-label={`${level.track.title} example questions`}>
            {level.mockups.map((mockup) => <CourseQuestionMockup mockup={mockup} compact />)}
          </div>
        </div>
      </section>
    ))}
  </main>

  <style>
    .track-hero {
      display: grid;
      min-height: min(680px, calc(100vh - 72px));
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.7fr);
      gap: 34px;
      align-items: center;
      padding-block: 42px;
    }

    .back-link {
      display: inline-flex;
      min-height: 38px;
      align-items: center;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 7px 11px;
      box-shadow: 3px 3px 0 var(--ink);
      font-weight: 1000;
      text-decoration: none;
    }

    .track-hero h1 {
      margin-top: 10px;
      font-size: clamp(3.2rem, 8vw, 7rem);
      line-height: 0.92;
    }

    .track-stat-row,
    .level-stat-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .track-stat-row span,
    .level-stat-row span {
      display: inline-flex;
      min-height: 38px;
      align-items: center;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 8px 11px;
      font-weight: 950;
    }

    .track-hero-panel {
      border: 3px solid var(--ink);
      border-radius: 8px;
      background:
        linear-gradient(135deg, color-mix(in srgb, var(--course-color) 18%, transparent) 0 24%, transparent 24% 100%),
        #fffaf0;
      box-shadow: 6px 6px 0 var(--block-shadow);
      padding: 22px;
    }

    .track-hero-panel h2 {
      font-size: 2.2rem;
    }

    .track-outcome-list {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    .track-outcome-list div {
      border-left: 10px solid var(--course-color);
      background: white;
      padding: 10px 12px;
    }

    .track-outcome-list strong {
      display: block;
      font-family: var(--font-display);
      font-size: 1.2rem;
    }

    .track-outcome-list p {
      color: var(--muted);
      font-weight: 850;
    }

    .level-nav-band,
    .level-section {
      border-top: 2px solid color-mix(in srgb, var(--line) 70%, transparent);
    }

    .level-nav {
      display: grid;
      grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
      gap: 24px;
      align-items: center;
      padding-block: 38px;
    }

    .level-nav nav {
      display: flex;
      flex-wrap: wrap;
      gap: 9px;
    }

    .level-nav a {
      display: inline-flex;
      min-height: 36px;
      align-items: center;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 7px 10px;
      color: var(--ink);
      font-weight: 950;
      text-decoration: none;
    }

    .level-section {
      padding-block: 52px;
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--course-color) 10%, transparent), transparent 44%),
        color-mix(in srgb, var(--paper) 74%, transparent);
    }

    .level-section:nth-of-type(2n) {
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--course-accent) 12%, transparent), transparent 42%),
        #fffaf0;
    }

    .level-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
      gap: 30px;
      align-items: start;
    }

    .level-kicker {
      color: color-mix(in srgb, var(--course-color) 70%, var(--ink));
      font-weight: 1000;
      text-transform: uppercase;
    }

    .level-copy h2 {
      margin-top: 8px;
      font-size: clamp(2rem, 5vw, 4rem);
    }

    .level-stat-row {
      margin-top: 16px;
    }

    .level-paragraphs {
      display: grid;
      max-width: 820px;
      gap: 12px;
      margin-top: 20px;
      color: var(--muted);
      font-weight: 820;
    }

    .unit-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 22px;
    }

    .unit-strip span {
      display: inline-flex;
      min-height: 34px;
      align-items: center;
      border: 2px solid color-mix(in srgb, var(--ink) 72%, var(--course-color));
      border-radius: 8px;
      background: white;
      padding: 7px 10px;
      font-size: 0.9rem;
      font-weight: 900;
    }

    .level-examples {
      display: grid;
      gap: 18px;
    }

    @media (max-width: 900px) {
      .track-hero,
      .level-nav,
      .level-layout {
        grid-template-columns: 1fr;
      }

      .track-hero {
        min-height: auto;
      }
    }

    @media (max-width: 767px) {
      .track-hero {
        padding-block: 28px;
      }

      .level-nav,
      .level-section {
        padding-block: 30px;
      }
    }
  </style>
</AppLayout>
