---
import CourseQuestionMockup from '../../components/CourseQuestionMockup.astro';
import PublicFooter from '../../components/PublicFooter.astro';
import PublicTopbar from '../../components/PublicTopbar.astro';
import AppLayout from '../../layouts/AppLayout.astro';
import { getCourseFamilies, getCourseLevels, type CourseFamily } from '../../lib/public-courses';
import { absoluteUrl, courseFamilyGraph, resolveSiteUrl, webPageGraph } from '../../lib/seo';

interface Props {
  family: CourseFamily;
}

export function getStaticPaths() {
  return getCourseFamilies().map((family) => ({
    params: { track: family.slug },
    props: { family },
  }));
}

const { family } = Astro.props;
const levels = getCourseLevels(family);
const siteUrl = resolveSiteUrl(Astro.site);
const courseTitle = `${family.title} Learning Courses | Buddy Blocks`;
const courseDescription = family.summary;
const courseCanonical = absoluteUrl(siteUrl, `/courses/${family.slug}/`);
const courseGraph = webPageGraph({
  site: siteUrl,
  canonicalUrl: courseCanonical,
  title: courseTitle,
  description: courseDescription,
  breadcrumbs: [
    { name: 'Home', path: '/' },
    { name: 'Courses', path: '/courses/' },
    { name: family.title, path: `/courses/${family.slug}/` },
  ],
  pageType: 'CollectionPage',
  extra: [courseFamilyGraph(siteUrl, family)],
});
---

<AppLayout
  title={courseTitle}
  description={courseDescription}
  canonicalPath={`/courses/${family.slug}/`}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Courses', path: '/courses/' },
    { name: family.title, path: `/courses/${family.slug}/` },
  ]}
  structuredData={courseGraph}
  showNav={false}
>
  <PublicTopbar active="courses" />

  <main style={`--course-color: ${family.color}; --course-accent: ${family.accent};`}>
    <section class="app-shell track-hero">
      <div>
        <a class="back-link" href="/courses/">All Courses</a>
        <p class="mt-5 font-black uppercase text-berryDark">{family.eyebrow}</p>
        <h1>{family.title}</h1>
        <p class="mt-5 max-w-3xl text-xl font-extrabold text-muted">{family.summary}</p>
        <div class="track-stat-row mt-7" aria-label={`${family.title} course totals`}>
          <span>{family.levelRange}</span>
          <span>{family.stats.units} units</span>
          <span>{family.stats.lessons} lesson briefs</span>
          <span>{family.stats.questions.toLocaleString()} question prompts</span>
        </div>
      </div>
    </section>

    {levels.map((level) => (
      <section class="level-section" id={level.track.slug}>
        <div class="app-shell level-layout">
          <article class="level-copy">
            <p class="level-kicker">{level.label}</p>
            <h2>{level.track.title}</h2>
            <div class="level-stat-row" aria-label={`${level.track.title} totals`}>
              <span>{level.stats.units} units</span>
              <span>{level.stats.lessons} lesson briefs</span>
              <span>{level.stats.questions} question prompts</span>
            </div>
            <div class="level-paragraphs">
              {level.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>

            <ul class="unit-strip" aria-label={`${level.track.title} units`}>
              {level.unitTitles.map((unit) => <li>{unit}</li>)}
            </ul>
          </article>

          <div class="level-examples" aria-label={`${level.track.title} example questions`}>
            {level.mockups.map((mockup) => <CourseQuestionMockup mockup={mockup} compact />)}
          </div>
        </div>
      </section>
    ))}
  </main>

  <PublicFooter />

  <style>
    .track-hero {
      padding-block: 42px;
    }

    .track-hero > div {
      max-width: 900px;
    }

    .back-link {
      display: inline-flex;
      min-height: 38px;
      align-items: center;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 7px 11px;
      box-shadow: 3px 3px 0 var(--ink);
      font-weight: 1000;
      text-decoration: none;
    }

    .track-hero h1 {
      margin-top: 10px;
      font-size: clamp(3.2rem, 8vw, 7rem);
      line-height: 0.92;
    }

    .track-stat-row,
    .level-stat-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .track-stat-row span,
    .level-stat-row span {
      display: inline-flex;
      min-height: 38px;
      align-items: center;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 8px 11px;
      font-weight: 950;
    }

    .level-section {
      border-top: 2px solid color-mix(in srgb, var(--line) 70%, transparent);
    }

    .level-section {
      padding-block: 52px;
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--course-color) 10%, transparent), transparent 44%),
        color-mix(in srgb, var(--paper) 74%, transparent);
    }

    .level-section:nth-of-type(2n) {
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--course-accent) 12%, transparent), transparent 42%),
        #fffaf0;
    }

    .level-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
      gap: 30px;
      align-items: start;
    }

    .level-kicker {
      color: color-mix(in srgb, var(--course-color) 70%, var(--ink));
      font-weight: 1000;
      text-transform: uppercase;
    }

    .level-copy h2 {
      margin-top: 8px;
      font-size: clamp(2rem, 5vw, 4rem);
    }

    .level-stat-row {
      margin-top: 16px;
    }

    .level-paragraphs {
      display: grid;
      max-width: 820px;
      gap: 12px;
      margin-top: 20px;
      color: var(--muted);
      font-weight: 820;
    }

    .unit-strip {
      display: grid;
      gap: 7px;
      margin: 22px 0 0;
      padding-left: 22px;
      color: var(--muted);
      font-weight: 850;
      list-style: disc;
    }

    .unit-strip li {
      display: list-item;
    }

    .unit-strip li::marker {
      color: var(--course-color);
    }

    .level-examples {
      display: grid;
      gap: 18px;
    }

    @media (max-width: 900px) {
      .level-layout {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 767px) {
      .track-hero {
        padding-block: 28px;
      }

      .level-section {
        padding-block: 30px;
      }
    }
  </style>
</AppLayout>
