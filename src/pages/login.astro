---
import BrandMark from '../components/BrandMark.astro';
import AppLayout from '../layouts/AppLayout.astro';

const hasError = Astro.url.searchParams.get('error') === '1';
---

<AppLayout title="Log in · Buddy Blocks" showNav={false}>
  <main class="min-h-screen px-4 py-8 sm:py-12">
    <section class="mx-auto grid min-h-[calc(100vh-4rem)] w-full max-w-5xl items-center gap-8 md:grid-cols-[0.9fr_1.1fr]">
      <div>
        <BrandMark href="/login/" />
        <h1 class="mt-8 text-[clamp(3.2rem,10vw,6.5rem)] leading-none">Buddy Blocks</h1>
        <p class="mt-5 max-w-xl text-xl font-extrabold text-muted">
          Colorful lessons for Math, Vocabulary, and Spanish, ready for Reagan and Ada.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <span class="stat-chip">Parent account: bill</span>
          <span class="stat-chip">Local seed password: blocks</span>
        </div>
      </div>

      <form method="post" action="/login/" class="block-card p-6 sm:p-8">
        <h2 class="text-3xl">Parent Sign In</h2>
        <p class="mt-3 font-bold text-muted">Use the fixed v1 parent account to choose a child profile.</p>
        {hasError && <p class="mt-4 rounded-lg border-2 border-berry bg-wash p-3 font-black text-berryDark">That login did not match the seeded parent account.</p>}
        <label class="mt-6 block font-black" for="identifier">Username or email</label>
        <input
          id="identifier"
          name="identifier"
          autocomplete="username"
          inputmode="email"
          value="bill"
          class="mt-2 min-h-[54px] w-full rounded-lg border-[3px] border-ink bg-white px-4 font-extrabold outline-none focus:ring-4 focus:ring-reward"
        />
        <label class="mt-5 block font-black" for="password">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          class="mt-2 min-h-[54px] w-full rounded-lg border-[3px] border-ink bg-white px-4 font-extrabold outline-none focus:ring-4 focus:ring-reward"
        />
        <button class="primary-button mt-7 w-full" type="submit">Open Profiles</button>
      </form>
    </section>
  </main>
</AppLayout>

