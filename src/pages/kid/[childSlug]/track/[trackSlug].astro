---
import TrackOverview from '../../../../components/islands/TrackOverview';
import { getTrackPaths } from '../../../../lib/content';
import AppLayout from '../../../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return getTrackPaths().map((path) => ({ params: { childSlug: path.childSlug, trackSlug: path.trackSlug } }));
}

const { childSlug, trackSlug } = Astro.params;
---

<AppLayout title="Track · Buddy Blocks" active="kid">
  <main class="app-shell page-band">
    <TrackOverview childSlug={childSlug!} trackSlug={trackSlug!} client:load />
  </main>
</AppLayout>
