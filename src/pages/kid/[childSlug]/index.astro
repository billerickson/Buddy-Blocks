---
import KidHome from '../../../components/islands/KidHome';
import { CHILDREN } from '../../../lib/content';
import AppLayout from '../../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return CHILDREN.map((child) => ({ params: { childSlug: child.slug } }));
}

const { childSlug } = Astro.params;
---

<AppLayout title="Home · Buddy Blocks" active="kid">
  <main class="app-shell page-band">
    <KidHome childSlug={childSlug!} client:load />
  </main>
</AppLayout>

