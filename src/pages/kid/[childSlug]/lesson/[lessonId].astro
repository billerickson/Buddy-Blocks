---
import LessonPlayer from '../../../../components/islands/LessonPlayer';
import { getLessonPaths } from '../../../../lib/seed-family';
import AppLayout from '../../../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return getLessonPaths().map((path) => ({ params: { childSlug: path.childSlug, lessonId: path.lessonId } }));
}

const { childSlug, lessonId } = Astro.params;
---

<AppLayout title="Lesson · Buddy Blocks" active="kid">
  <main class="app-shell page-band">
    <LessonPlayer childSlug={childSlug!} lessonId={lessonId!} client:load />
  </main>
</AppLayout>
