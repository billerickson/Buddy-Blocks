---
import PublicTopbar from '../components/PublicTopbar.astro';
import PublicFooter from '../components/PublicFooter.astro';
import AppLayout from '../layouts/AppLayout.astro';
import { getCourseFamilies } from '../lib/public-courses';
import { SITE_NAME, absoluteUrl, resolveSiteUrl, webPageGraph } from '../lib/seo';

const screenshotCards = [
  {
    image: '/screenshots/kid-dashboard.jpg',
    webpSrcSet: '/screenshots/kid-dashboard-640.webp 640w',
    alt: 'Buddy Blocks kid dashboard showing subject tracks and progress cards',
    width: 1218,
    height: 816,
    eyebrow: 'Kid dashboard',
    title: 'Each learner sees a clear path',
    description:
      'Profiles open into colorful subject tracks with progress, hearts, streaks, and the next best lesson ready to tap.',
  },
  {
    image: '/screenshots/lesson-player.jpg',
    webpSrcSet: '/screenshots/lesson-player-640.webp 640w',
    alt: 'Buddy Blocks lesson player with a multiple choice vocabulary question',
    width: 916,
    height: 520,
    eyebrow: 'Lesson player',
    title: 'Short practice that feels hands-on',
    description:
      'Questions use big touch targets, immediate feedback, XP rewards, and review prompts that help kids recover quickly.',
  },
  {
    image: '/screenshots/parent-dashboard.jpg',
    webpSrcSet: '/screenshots/parent-dashboard-640.webp 640w',
    alt: 'Buddy Blocks parent dashboard showing progress across subjects',
    width: 1218,
    height: 868,
    eyebrow: 'Parent dashboard',
    title: 'Progress without digging',
    description:
      'Parents can scan recent work, see where help is needed, and create targeted practice sets from current school work.',
  },
];

const workflowSteps = [
  ['1', 'Parent signs in', 'A single parent login keeps profiles, progress, and parent controls in one private space.'],
  ['2', 'Kids pick a profile', 'Each child gets a friendly home screen with lessons matched to their grade and foundation levels.'],
  ['3', 'Lessons stack into progress', 'Quick sessions award XP, protect streaks, track mistakes, and unlock the next block of work.'],
  ['4', 'Parents adjust the focus', 'The dashboard shows momentum and lets parents add practice for spelling, vocabulary, or review.'],
];

const featureCards = [
  ['Multi-subject tracks', 'Math, vocabulary, grammar, logic, language, and classical foundations can live side by side.'],
  ['Kid-sized sessions', 'Lessons are compact, tappable, and built for the kind of focus kids can actually sustain.'],
  ['Progress that is visible', 'XP, hearts, streaks, badges, and completion rails make effort easy to see.'],
  ['Parent-created practice', 'Turn a spelling list, vocabulary set, or review topic into a practice track without changing the core curriculum.'],
  ['Mistake review loop', 'Missed work becomes part of the learning path instead of disappearing after one attempt.'],
  ['PWA-friendly interface', 'The app is designed for tablets, home screens, and repeat daily use.'],
];

const scienceCards = [
  ['Meaning before memory', 'New words, facts, and patterns start with short teaching cards, examples, passages, or worked models before kids are asked to recall them.'],
  ['Guided recognition', 'Early questions help students notice the clue, definition, or pattern so practice begins with understanding instead of guessing.'],
  ['Varied retrieval', 'Multiple question types ask kids to choose, match, order, type, and explain, which strengthens long-term retention after meaningful study.'],
  ['Spaced mixed review', 'Older material returns in later cumulative lessons so practice is spaced and interleaved, not crammed into one sitting.'],
];

const benefitCards = [
  ['Less planning overhead', 'Buddy Blocks keeps the next lesson visible so school practice does not start with a scavenger hunt.'],
  ['More independent practice', 'Kids can move through familiar screens with clear goals, rewards, and recovery when they miss.'],
  ['Better parent visibility', 'Parents get a calm view of progress, weak spots, streaks, and recent activity.'],
];

const courseFamilies = getCourseFamilies();
const courseTotals = courseFamilies.reduce(
  (summary, family) => ({
    levels: summary.levels + family.stats.levels,
    units: summary.units + family.stats.units,
    lessons: summary.lessons + family.stats.lessons,
    questions: summary.questions + family.stats.questions,
  }),
  { levels: 0, units: 0, lessons: 0, questions: 0 },
);
const homeTitle = 'Buddy Blocks | Self-Hosted Learning App for Families';
const homeDescription =
  'Buddy Blocks is a self-hosted family learning app with short lessons, parent dashboards, progress rewards, and classical course paths for kids.';
const siteUrl = resolveSiteUrl(Astro.site);
const homeCanonical = absoluteUrl(siteUrl, '/');
const homeGraph = webPageGraph({
  site: siteUrl,
  canonicalUrl: homeCanonical,
  title: homeTitle,
  description: homeDescription,
  breadcrumbs: [{ name: 'Home', path: '/' }],
  extra: [
    {
      '@type': 'SoftwareApplication',
      '@id': `${homeCanonical}#software`,
      name: SITE_NAME,
      description: homeDescription,
      url: homeCanonical,
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'Web browser',
      educationalUse: ['Practice', 'Review', 'Homeschool support'],
      audience: {
        '@type': 'EducationalAudience',
        educationalRole: 'student',
      },
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    },
  ],
});
---

<AppLayout
  title={homeTitle}
  description={homeDescription}
  canonicalPath="/"
  breadcrumbs={[{ name: 'Home', path: '/' }]}
  structuredData={homeGraph}
  showNav={false}
>
  <PublicTopbar active="home" />

  <main>
    <section class="app-shell grid items-center gap-10 py-10 lg:grid-cols-[0.94fr_1.06fr] lg:py-12">
      <div>
        <img class="hero-moxie" src="/icons/moxie.svg" alt="" width="220" height="220" decoding="async" fetchpriority="high" />
        <h1 class="mt-7 text-[clamp(3.4rem,8vw,7rem)] leading-none">Buddy Blocks</h1>
        <p class="mt-5 max-w-2xl text-xl font-extrabold text-muted">
          A colorful learning app where kids build progress one small lesson at a time, and parents can see what is working without turning practice into a project.
        </p>
      </div>

      <div class="hero-screenshot" aria-label="Buddy Blocks sample dashboard screenshot">
        <div class="screen-top">
          <span>Maya's Blocks</span>
          <span>7 day streak</span>
        </div>
        <div class="screen-body">
          <div class="screen-profile">
            <span class="screen-avatar">M</span>
            <div>
              <strong>Ready for today?</strong>
              <p>3 lessons planned &middot; 420 XP</p>
            </div>
          </div>
          <div class="screen-track screen-track-teal">
            <div>
              <strong>Math Foundations</strong>
              <p>Next: mixed facts</p>
            </div>
            <span>72%</span>
          </div>
          <div class="screen-track screen-track-blue">
            <div>
              <strong>Spanish 1</strong>
              <p>Next: color words</p>
            </div>
            <span>45%</span>
          </div>
          <div class="screen-track screen-track-orange">
            <div>
              <strong>Logic</strong>
              <p>Next: patterns</p>
            </div>
            <span>30%</span>
          </div>
          <div class="screen-footer">
            <span>5 hearts</span>
            <span>2 badges earned</span>
          </div>
        </div>
      </div>
    </section>

    <section id="get-your-own-copy" class="homepage-band bg-white py-14">
      <div class="app-shell">
        <div class="get-copy-layout">
          <div>
            <h2 class="text-4xl">Get your own copy</h2>
            <p class="mt-4 text-lg font-bold text-muted">
              Point Codex, Claude, Hermes, or another AI agent at the
              <a class="copy-link" href="https://github.com/billerickson/Buddy-Blocks/blob/master/AGENTS.md" target="_blank" rel="noopener noreferrer">AGENTS.md</a>
              setup file and it can set up Buddy Blocks for you. You just need a free Cloudflare account and a domain managed there. It will deploy your copy at
              <a class="copy-link" href="https://buddyblocks.yoursite.com" target="_blank" rel="noopener noreferrer">https://buddyblocks.yoursite.com</a>.
            </p>
            <a class="secondary-button mt-5" href="https://github.com/billerickson/Buddy-Blocks/blob/master/AGENTS.md" target="_blank" rel="noopener noreferrer">Open AGENTS.md</a>
          </div>

          <form class="hosted-interest-form" data-hosted-interest-form action="/api/hosted-interest" method="post" novalidate>
            <h3 class="text-3xl">Want a hosted version?</h3>
            <p class="mt-3 font-bold text-muted">
              Would you be interested in a paid, cloud-hosted version of Buddy Blocks so you do not have to set it up? Share your email and we will let you know if or when it is available.
            </p>

            <div class="hosted-interest-fields mt-5" data-hosted-interest-fields>
              <label class="sr-only" for="hosted-interest-email">Email address</label>
              <input
                id="hosted-interest-email"
                name="email"
                type="email"
                inputmode="email"
                autocomplete="email"
                placeholder="Email address"
                required
              />
              <input type="hidden" name="source" value="homepage" />
              <button class="primary-button" type="submit" data-hosted-interest-submit>Let me know</button>
            </div>

            <p class="hosted-interest-status" data-hosted-interest-status role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="homepage-band py-14">
      <div class="app-shell">
        <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-center">
          <div>
            <p class="font-black uppercase text-berryDark">How It Works</p>
            <h2 class="mt-3 text-4xl">A simple loop for daily learning</h2>
            <p class="mt-4 text-lg font-bold text-muted">
              Buddy Blocks keeps the grown-up setup separate from the kid practice loop, so each session can start quickly and end with visible progress.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {workflowSteps.map(([number, title, description]) => (
              <article class="step-card">
                <span>{number}</span>
                <h3 class="mt-4 text-2xl">{title}</h3>
                <p class="mt-3 font-bold text-muted">{description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="screenshots" class="homepage-band bg-white py-14">
      <div class="app-shell">
        <div class="max-w-3xl">
          <h2 class="text-4xl">What Buddy Blocks looks like</h2>
        </div>

        <div class="screenshot-sections mt-8">
          {screenshotCards.map((card, index) => (
            <article class={`screenshot-row ${index % 2 === 1 ? 'screenshot-row-reversed' : ''}`}>
              <figure class="screenshot-frame">
                <picture>
                  <source type="image/webp" srcset={card.webpSrcSet} sizes="(max-width: 900px) calc(100vw - 32px), 58vw" />
                  <img
                    src={card.image}
                    alt={card.alt}
                    width={card.width}
                    height={card.height}
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              </figure>
              <div class="screenshot-copy">
                <p class="font-black uppercase text-berryDark">{card.eyebrow}</p>
                <h3 class="mt-2 text-3xl">{card.title}</h3>
                <p class="mt-4 text-lg font-bold text-muted">{card.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="learning-science" class="homepage-band py-14">
      <div class="app-shell">
        <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
          <div>
            <p class="font-black uppercase text-berryDark">Research-Based Learning</p>
            <h2 class="mt-3 text-4xl">Lessons are sequenced for retention</h2>
            <p class="mt-4 text-lg font-bold text-muted">
              Buddy Blocks uses research-backed practices from explicit instruction, contextual exposure, retrieval practice, spacing, interleaving, and feedback. Kids meet ideas first, practice with support, then build toward harder recall.
            </p>
          </div>
          <div class="science-sequence">
            {scienceCards.map(([title, description], index) => (
              <article class="science-card">
                <span>{index + 1}</span>
                <div>
                  <h3 class="text-2xl">{title}</h3>
                  <p class="mt-2 font-bold text-muted">{description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="courses" class="homepage-band bg-white py-14">
      <div class="app-shell">
        <div class="courses-heading">
          <div>
            <p class="font-black uppercase text-berryDark">Course families</p>
            <h2 class="mt-3 text-4xl">Courses that build lasting skills, step by step</h2>
          </div>
          <div>
            <p class="text-lg font-bold text-muted">
              Buddy Blocks gives students a clear path through a classical education with short, engaging lesson briefs that combine practice, examples, and review. Classical Literature now spans five levels, from fables and myths to capstone classical reading.
            </p>
            <div class="home-course-stats mt-5" aria-label="Curriculum totals">
              <span><strong>{courseFamilies.length}</strong> course families</span>
              <span><strong>{courseTotals.levels}</strong> levels</span>
              <span><strong>{courseTotals.lessons}</strong> lesson briefs</span>
              <span><strong>{courseTotals.questions.toLocaleString()}</strong> question prompts</span>
            </div>
          </div>
        </div>

        <div class="course-card-grid mt-8">
          {courseFamilies.map((family) => (
            <a class="home-course-card" href={`/courses/${family.slug}/`} style={`--course-color: ${family.color}; --course-accent: ${family.accent};`}>
              <div>
                <p>{family.levelRange}</p>
                <h3>{family.title}</h3>
              </div>
              <p class="home-course-summary">{family.summary}</p>
              <div class="home-course-progress" aria-label={`${family.title} course size`}>
                <span class="progress-rail"><span class="progress-fill" style={`width: ${Math.max(38, Math.min(96, family.stats.levels * 8))}%`}></span></span>
                <span>{family.stats.levels} {family.stats.levels === 1 ? 'level' : 'levels'} &middot; {family.stats.lessons} lesson briefs &middot; {family.stats.questions.toLocaleString()} question prompts</span>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-8">
          <a class="primary-button" href="/courses/">More About Courses</a>
        </div>
      </div>
    </section>

    <section id="features" class="homepage-band bg-white py-14">
      <div class="app-shell">
        <div class="max-w-3xl">
          <p class="font-black uppercase text-berryDark">Features</p>
          <h2 class="mt-3 text-4xl">Built around the learning loop</h2>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {featureCards.map(([title, description]) => (
            <article class="feature-card">
              <h3 class="text-2xl">{title}</h3>
              <p class="mt-3 font-bold text-muted">{description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="homepage-band py-14">
      <div class="app-shell">
        <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr]">
          <div>
            <p class="font-black uppercase text-berryDark">Benefits</p>
            <h2 class="mt-3 text-4xl">Practice that is easier to keep going</h2>
          </div>
          <div class="grid gap-4">
            {benefitCards.map(([title, description]) => (
              <article class="benefit-row">
                <h3 class="text-2xl">{title}</h3>
                <p class="font-bold text-muted">{description}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <PublicFooter />

  <style>
    .homepage-band {
      border-top: 2px solid color-mix(in srgb, var(--line) 70%, transparent);
      scroll-margin-top: 86px;
    }

    .hero-screenshot,
    .step-card,
    .feature-card,
    .science-card,
    .benefit-row {
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      box-shadow: 6px 6px 0 var(--block-shadow);
    }

    .hero-screenshot {
      overflow: hidden;
      transform: rotate(1deg);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .hero-moxie {
      display: block;
      width: clamp(88px, 12vw, 132px);
      height: auto;
    }

    .screen-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 3px solid var(--ink);
      background: var(--secondary);
      padding: 14px 16px;
      font-weight: 1000;
    }

    .screen-body {
      display: grid;
      gap: 14px;
      padding: 18px;
      background:
        linear-gradient(135deg, rgba(24, 188, 164, 0.14) 0 18%, transparent 18% 100%),
        linear-gradient(225deg, rgba(91, 121, 255, 0.13) 0 16%, transparent 16% 100%),
        #fffaf0;
    }

    .screen-profile,
    .screen-track,
    .screen-footer {
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: #fff;
    }

    .screen-profile {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
    }

    .screen-avatar {
      display: inline-grid;
      width: 52px;
      height: 52px;
      place-items: center;
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: var(--primary);
      color: white;
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 800;
    }

    .screen-track,
    .screen-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 13px 14px;
      font-weight: 900;
    }

    .screen-track p,
    .screen-profile p {
      color: var(--muted);
      font-weight: 800;
    }

    .screen-track-teal {
      border-left: 12px solid var(--accent);
    }

    .screen-track-blue {
      border-left: 12px solid var(--accent-two);
    }

    .screen-track-orange {
      border-left: 12px solid var(--accent-three);
    }

    .screen-footer {
      background: #f0fff9;
    }

    .step-card,
    .feature-card {
      padding: 18px;
    }

    .screenshot-sections {
      display: grid;
      gap: 28px;
    }

    .screenshot-row {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      gap: 28px;
      align-items: center;
    }

    .screenshot-row-reversed {
      grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1.2fr);
    }

    .screenshot-row-reversed .screenshot-frame {
      order: 2;
    }

    .screenshot-row-reversed .screenshot-copy {
      order: 1;
    }

    .screenshot-frame {
      margin: 0;
      overflow: hidden;
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      box-shadow: 6px 6px 0 var(--block-shadow);
    }

    .screenshot-frame picture {
      display: block;
    }

    .screenshot-frame img {
      display: block;
      width: 100%;
      height: auto;
    }

    .screenshot-copy {
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: #fffaf0;
      box-shadow: 6px 6px 0 var(--block-shadow);
      padding: 24px;
    }

    .step-card span {
      display: inline-grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: var(--accent);
      color: white;
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 800;
    }

    .feature-card:nth-child(2n) {
      background: #fffaf0;
    }

    .feature-card:nth-child(3n) {
      background: #f0fff9;
    }

    .science-sequence {
      display: grid;
      gap: 14px;
    }

    .science-card {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 16px;
      align-items: start;
      padding: 18px;
    }

    .science-card span {
      display: inline-grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: var(--secondary);
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 800;
    }

    .benefit-row {
      display: grid;
      grid-template-columns: minmax(0, 0.42fr) minmax(0, 0.58fr);
      gap: 18px;
      align-items: center;
      padding: 18px;
    }

    .courses-heading {
      display: grid;
      grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
      gap: 28px;
      align-items: center;
    }

    .home-course-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .home-course-stats span {
      display: inline-flex;
      min-height: 40px;
      align-items: center;
      gap: 6px;
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--paper);
      padding: 8px 11px;
      font-weight: 950;
    }

    .home-course-stats strong {
      font-family: var(--font-display);
      font-size: 1.25rem;
    }

    .course-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 285px), 1fr));
      gap: 18px;
    }

    .home-course-card {
      display: grid;
      min-height: 250px;
      gap: 14px;
      align-content: space-between;
      border: 3px solid var(--ink);
      border-left: 12px solid var(--course-color);
      border-radius: 8px;
      background:
        linear-gradient(135deg, color-mix(in srgb, var(--course-color) 11%, transparent) 0 26%, transparent 26% 100%),
        var(--paper);
      box-shadow: 6px 6px 0 var(--block-shadow);
      padding: 18px;
      text-decoration: none;
      transition:
        transform 120ms ease,
        box-shadow 120ms ease;
    }

    .home-course-card:hover {
      transform: translate(2px, 2px);
      box-shadow: 3px 3px 0 var(--block-shadow);
    }

    .home-course-card > div:first-child {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .home-course-card > div:first-child p {
      border: 2px solid var(--ink);
      border-radius: 8px;
      background: var(--secondary);
      padding: 5px 8px;
      font-size: 0.82rem;
      font-weight: 1000;
      white-space: nowrap;
    }

    .home-course-card h3 {
      max-width: 190px;
      font-size: 2rem;
    }

    .home-course-summary {
      color: var(--muted);
      font-weight: 850;
    }

    .home-course-progress {
      display: grid;
      gap: 8px;
      color: var(--muted);
      font-weight: 950;
    }

    .home-course-progress .progress-fill {
      background: linear-gradient(90deg, var(--course-color), var(--course-accent));
    }

    .get-copy-layout {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
      gap: 28px;
      align-items: start;
    }

    .copy-link {
      color: var(--primary-dark);
      font-weight: 1000;
      text-decoration-thickness: 3px;
      text-underline-offset: 4px;
    }

    .hosted-interest-form {
      border: 3px solid var(--ink);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(255, 216, 77, 0.24) 0 28%, transparent 28% 100%),
        var(--paper);
      box-shadow: 6px 6px 0 var(--block-shadow);
      padding: 24px;
    }

    .hosted-interest-fields {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 12px;
      align-items: stretch;
    }

    .hosted-interest-fields input[type='email'] {
      min-height: 50px;
      width: 100%;
      border: 3px solid var(--ink);
      border-radius: 8px;
      background: #fff;
      padding: 12px 14px;
      color: var(--ink);
      font-weight: 900;
      outline: none;
    }

    .hosted-interest-fields input[type='email']:focus {
      box-shadow: 0 0 0 4px var(--secondary);
    }

    .hosted-interest-fields input[type='email'][aria-invalid='true'] {
      border-color: var(--primary-dark);
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--primary) 22%, transparent);
    }

    .hosted-interest-form[data-success='true'] .hosted-interest-fields {
      display: none;
    }

    .hosted-interest-status {
      min-height: 1.55em;
      margin-top: 12px;
      font-weight: 1000;
      color: var(--muted);
    }

    .hosted-interest-status:empty {
      display: none;
    }

    .hosted-interest-status[data-state='success'] {
      color: #0d7668;
    }

    .hosted-interest-status[data-state='error'] {
      color: var(--primary-dark);
    }

    @media (max-width: 767px) {
      .hero-screenshot {
        transform: none;
      }

      .hero-moxie {
        width: 84px;
      }

      .screen-top,
      .screen-footer {
        align-items: flex-start;
        flex-direction: column;
        gap: 4px;
      }

      .benefit-row {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .courses-heading {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .get-copy-layout,
      .hosted-interest-fields {
        grid-template-columns: 1fr;
      }

      .hosted-interest-form {
        padding: 18px;
      }

      .screenshot-row,
      .screenshot-row-reversed {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .screenshot-row-reversed .screenshot-frame,
      .screenshot-row-reversed .screenshot-copy {
        order: initial;
      }

      .screenshot-copy {
        padding: 16px;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const form = document.querySelector('[data-hosted-interest-form]');
      if (!(form instanceof HTMLFormElement)) return;

      const emailInput = form.querySelector('input[name="email"]');
      const sourceInput = form.querySelector('input[name="source"]');
      const submit = form.querySelector('[data-hosted-interest-submit]');
      const status = form.querySelector('[data-hosted-interest-status]');
      if (!(emailInput instanceof HTMLInputElement) || !(sourceInput instanceof HTMLInputElement)) return;

      const setStatus = (state, message) => {
        if (!status) return;
        status.dataset.state = state;
        status.textContent = message;
      };

      const setSubmitting = (submitting) => {
        if (submit instanceof HTMLButtonElement) {
          submit.disabled = submitting;
          submit.textContent = submitting ? 'Saving...' : 'Let me know';
        }
        emailInput.disabled = submitting;
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        form.dataset.success = 'false';
        emailInput.setAttribute('aria-invalid', 'false');
        setStatus('idle', '');

        if (!emailInput.validity.valid) {
          emailInput.setAttribute('aria-invalid', 'true');
          setStatus('error', 'Enter a valid email address.');
          emailInput.focus();
          return;
        }

        setSubmitting(true);

        try {
          const response = await fetch('/api/hosted-interest', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify({
              email: emailInput.value.trim(),
              source: sourceInput.value,
            }),
          });

          if (!response.ok) {
            throw new Error(response.status === 400 ? 'invalid_email' : 'save_failed');
          }

          form.reset();
          form.dataset.success = 'true';
          setStatus('success', 'Thanks. We will let you know if a hosted version becomes available.');
        } catch (error) {
          const invalidEmail = error instanceof Error && error.message === 'invalid_email';
          if (invalidEmail) emailInput.setAttribute('aria-invalid', 'true');
          setStatus('error', invalidEmail ? 'Enter a valid email address.' : 'Something went wrong. Please try again in a moment.');
        } finally {
          setSubmitting(false);
        }
      });
    })();
  </script>
</AppLayout>
