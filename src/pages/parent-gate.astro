---
import BrandMark from '../components/BrandMark.astro';
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Parent check · Buddy Blocks" showNav={false}>
  <main class="min-h-screen px-4 py-8 sm:py-12">
    <section class="mx-auto grid min-h-[calc(100vh-4rem)] w-full max-w-5xl items-center gap-8 md:grid-cols-[0.95fr_1.05fr]">
      <div>
        <BrandMark href="/parent-gate/" />
        <p class="stat-chip mt-8 w-fit">Parent check</p>
        <h1 class="mt-5 text-[clamp(3rem,9vw,6rem)] leading-none">Grown-up password</h1>
        <p class="mt-5 max-w-xl text-xl font-extrabold text-muted">
          Enter Bill's password to open parent spaces or switch builders.
        </p>
      </div>

      <form method="post" action="/parent-gate/" class="block-card p-6 sm:p-8">
        <h2 class="text-3xl">Parent Password</h2>
        <p class="mt-3 font-bold text-muted">This keeps each kid in their own Buddy Blocks profile.</p>
        <p
          hidden
          data-parent-gate-error
          class="mt-4 rounded-lg border-2 border-berry bg-wash p-3 font-black text-berryDark"
        >
          That password did not match the parent account.
        </p>
        <input type="hidden" name="next" value="/parent/" data-parent-gate-next />
        <label class="mt-6 block font-black" for="password">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          autofocus
          class="mt-2 min-h-[54px] w-full rounded-lg border-[3px] border-ink bg-white px-4 font-extrabold outline-none focus:ring-4 focus:ring-reward"
        />
        <button class="primary-button mt-7 w-full" type="submit">Unlock Parent Mode</button>
        <a class="secondary-button mt-4 w-full" href="/" data-parent-gate-back>Go Back</a>
      </form>
    </section>
  </main>

  <script is:inline>
    const params = new URLSearchParams(window.location.search);
    const nextInput = document.querySelector('[data-parent-gate-next]');
    const requestedNext = params.get('next') || '/parent/';
    const safeNext = requestedNext.startsWith('/') && !requestedNext.startsWith('//') ? requestedNext : '/parent/';

    if (nextInput) nextInput.value = safeNext;
    if (params.get('error') === '1') document.querySelector('[data-parent-gate-error]')?.removeAttribute('hidden');

    const backLink = document.querySelector('[data-parent-gate-back]');
    if (backLink && document.referrer) {
      const referrer = new URL(document.referrer);
      if (referrer.origin === window.location.origin) backLink.href = referrer.pathname + referrer.search + referrer.hash;
    }
  </script>
</AppLayout>
