{
  "name": "buddy-blocks",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "dev:worker": "wrangler dev --config wrangler.deploy.jsonc --local --port 8787",
    "check": "env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "build": "env ASTRO_TELEMETRY_DISABLED=1 astro check && env ASTRO_TELEMETRY_DISABLED=1 astro build && npm run seo:validate",
    "preview": "astro preview --host 0.0.0.0",
    "test": "vitest run",
    "seo:validate": "tsx scripts/validate-seo.ts",
    "og:render-options": "node scripts/render-og-options.mjs",
    "content:validate": "tsx scripts/validate-content.ts",
    "content:promote": "tsx scripts/research-promotion.ts",
    "deploy:dry-run": "wrangler deploy --config wrangler.deploy.jsonc --dry-run",
    "deploy": "wrangler deploy --config wrangler.deploy.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply DB --config wrangler.deploy.jsonc --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --config wrangler.deploy.jsonc --remote",
    "db:seed:local": "tsx scripts/seed.ts --config wrangler.deploy.jsonc --local",
    "db:seed:remote": "tsx scripts/seed.ts --config wrangler.deploy.jsonc --remote",
    "db:reset:local": "wrangler d1 execute DB --config wrangler.deploy.jsonc --local --file scripts/reset-local.sql && npm run db:seed:local"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/tailwind": "latest",
    "astro": "latest",
    "preact": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "wrangler": "latest",
    "yaml": "^2.9.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@types/node": "^25.9.1",
    "node-html-parser": "^8.0.4",
    "vitest": "latest"
  }
}
