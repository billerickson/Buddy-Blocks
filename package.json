{
  "name": "buddy-blocks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "dev:worker": "wrangler dev --local --port 8787",
    "check": "env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "build": "env ASTRO_TELEMETRY_DISABLED=1 astro check && env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview --host 0.0.0.0",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply buddy_blocks --local",
    "db:migrate:remote": "wrangler d1 migrations apply buddy_blocks --remote",
    "db:seed:local": "tsx scripts/seed.ts --local",
    "db:seed:remote": "tsx scripts/seed.ts --remote",
    "db:reset:local": "wrangler d1 execute buddy_blocks --local --file scripts/reset-local.sql && npm run db:seed:local"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/tailwind": "latest",
    "astro": "latest",
    "preact": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "wrangler": "latest",
    "yaml": "^2.9.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@types/node": "^25.9.1",
    "vitest": "latest"
  }
}
